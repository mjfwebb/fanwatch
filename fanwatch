#!/usr/bin/env bash
# fanwatch - live fan/temperature monitor for Linux laptops and desktops.
# Shows CPU/GPU temps with trend arrows, a sparkline of recent CPU history, the
# live fan level/RPM, and a callout whenever the fan state changes. Reads from
# thinkpad_acpi (/proc/acpi/ibm) when present, else the generic hwmon sysfs
# interface; pick explicitly with FANWATCH_BACKEND. See `fanwatch --help`.
#
# Usage: fanwatch [interval_seconds] [--sticky|--no-sticky]   (default 2s, pinned)
#        fanwatch update                                       (self-update in place)
#        fanwatch --help

export LC_ALL=C

# Bump on release. install.sh greps this line to report what an update did.
# shellcheck disable=SC2034  # read externally by install.sh, not within this script
VERSION=0.3.0

# Subcommand: self-update by re-running the installer. Handled before the
# positional interval below, which would otherwise read "update" as an interval.
# FANWATCH_RAW_URL selects a fork/branch, matching install.sh's own override.
if [[ ${1:-} == update ]]; then
  shift
  command -v curl >/dev/null 2>&1 || { printf 'fanwatch: update needs curl on PATH\n' >&2; exit 1; }
  raw_url=${FANWATCH_RAW_URL:-https://raw.githubusercontent.com/mjfwebb/fanwatch/main}
  # pipefail so a failed download surfaces instead of being masked by bash
  # exiting 0 on empty stdin.
  set -o pipefail
  curl -fsSL "$raw_url/install.sh" | bash -s -- "$@"
  exit $?
fi

# --- options ----------------------------------------------------------------
print_help() {
  cat <<'EOF'
Usage: fanwatch [interval_seconds] [options]
       fanwatch update                  self-update in place

Options:
  --sticky        pin the header to the top of the terminal (default)
  --no-sticky     let the output scroll naturally, keeping scrollback
  --scroll        alias for --no-sticky
  -h, --help      show this help and exit

Environment:
  FANWATCH_STICKY=0   start in the scrolling layout (same as --no-sticky)
  FANWATCH_RISE=N     investigate CPU jumps of N°C or more (default 3)
  FANWATCH_BACKEND=X  force a backend: thinkpad | hwmon | macos (default: auto)
  FANWATCH_OFF_BELOW=N  green below N°C on the hwmon/macos backends (default 55;
                      the thinkpad backend derives this from thinkfan.yaml)

  Sensor overrides (hwmon backend; give a sysfs path to skip auto-detection):
  FANWATCH_CPU_TEMP, FANWATCH_GPU_TEMP   e.g. /sys/class/hwmon/hwmon7/temp1_input
  FANWATCH_FAN        one or more fan*_input paths (space-separated)
  FANWATCH_PWM        a pwm* path, shown as a percentage of 255

  macOS (reads the SMC via a helper tool on PATH):
  FANWATCH_MAC_TOOL=T force the helper: smctemp | istats | osx-cpu-temp |
                      powermetrics (default: first of those found)

While running, Shift+Tab toggles between the pinned and scrolling layouts.
EOF
}

# Pin the header by default (FANWATCH_STICKY=1); --no-sticky/--scroll or
# FANWATCH_STICKY=0 starts in the scrollback-friendly layout instead. Either way
# Shift+Tab flips between the two live.
STICKY_PREF="${FANWATCH_STICKY:-1}"
interval=2
while (( $# )); do
  case $1 in
    --sticky)             STICKY_PREF=1; shift;;
    --no-sticky|--scroll) STICKY_PREF=0; shift;;
    -h|--help)            print_help; exit 0;;
    --)                   shift; break;;
    -*)                   printf 'fanwatch: unknown option %s (try --help)\n' "$1" >&2; exit 2;;
    *)                    interval=$1; shift;;
  esac
done

# Investigate the likely culprit when CPU temp jumps by at least this many °C
# between samples (override with FANWATCH_RISE).
RISE="${FANWATCH_RISE:-3}"

# --- backend ----------------------------------------------------------------
# fanwatch reads CPU/GPU temperature, fan RPM and the fan's commanded level from
# whatever the platform exposes. thinkpad_acpi (/proc/acpi/ibm) is preferred
# when present: it names fan levels and pairs with thinkfan's config. Otherwise
# the generic Linux hwmon sysfs interface is used, which works on most laptops
# and desktops. FANWATCH_BACKEND forces the pick. Each backend defines a
# sample_<name> that fills the per-tick globals the loop prints (cpu, gpu, rpm,
# rpmdisp, leveltext, levelcolor, levelkey, fanoff) and returns non-zero when
# there is no CPU reading.
OS=$(uname -s 2>/dev/null || echo Linux)
IBM_FAN=/proc/acpi/ibm/fan
IBM_THERMAL=/proc/acpi/ibm/thermal
THINKFAN_CONFIG="${FANWATCH_THINKFAN_CONFIG:-/etc/thinkfan.yaml}"

detect_backend() {
  [[ -n ${FANWATCH_BACKEND:-} ]] && { printf '%s' "$FANWATCH_BACKEND"; return; }
  [[ $OS == Darwin ]]                && { printf 'macos';    return; }
  [[ -r $IBM_FAN && -r $IBM_THERMAL ]] && { printf 'thinkpad'; return; }
  printf 'hwmon'
}

# Derive the thinkpad off-threshold straight from thinkfan's config so it never
# goes stale: the fan drops to level 0 once temps fall below the LOWER bound of
# the lowest non-zero level. Parse each "- [level, lower, upper]" entry, skip
# level 0, and take the smallest lower bound. Falls back to 58 if unreadable.
parse_off_below() {
  local config=$1 v
  v=$(awk '
    /^[[:space:]]*-[[:space:]]*\[/ {
      s=$0; gsub(/.*\[/,"",s); gsub(/\].*/,"",s); n=split(s,a,",")
      lvl=a[1]; gsub(/[[:space:]"]/,"",lvl)
      low=a[2]; gsub(/[[:space:]]/,"",low)
      if (lvl!="0" && low ~ /^[0-9]+$/ && (min=="" || low+0<min)) min=low+0
    }
    END { print (min=="" ? 58 : min) }
  ' "$config" 2>/dev/null)
  [[ "$v" =~ ^[0-9]+$ ]] || v=58
  printf '%s' "$v"
}

# --- hwmon discovery --------------------------------------------------------
# Echo a hwmon device dir whose name matches a regex (first match wins).
hwmon_dir_by_name() {
  local root=$1 want=$2 d n
  for d in "$root"/hwmon*; do
    [[ -r $d/name ]] || continue
    read -r n < "$d/name"
    [[ $n =~ $want ]] && { printf '%s' "$d"; return; }
  done
}

# Echo the temp*_input under a dir whose temp*_label matches a regex; fall back
# to temp1_input. Echoes nothing if the dir has no usable temperature input.
hwmon_temp_by_label() {
  local dir=$1 want=$2 lf inp
  for lf in "$dir"/temp*_label; do
    [[ -r $lf ]] || continue
    if grep -qiE "$want" "$lf" 2>/dev/null; then
      inp="${lf%_label}_input"
      [[ -r $inp ]] && { printf '%s' "$inp"; return; }
    fi
  done
  [[ -r $dir/temp1_input ]] && printf '%s' "$dir/temp1_input"
}

# Resolve CPU temp, GPU temp, fan RPM input(s) and a PWM node from the hwmon
# tree. Honours the FANWATCH_* path overrides; sets HW_CPU/HW_GPU/HW_FANS/HW_PWM
# and the friendly source names used in the header.
discover_hwmon() {
  local root=$1 d
  HW_CPU=""; HW_GPU=""; HW_PWM=""; HW_CPU_NAME=""; HW_GPU_NAME=""; HW_FANS=()

  [[ -n ${FANWATCH_CPU_TEMP:-} ]] && { HW_CPU=$FANWATCH_CPU_TEMP; HW_CPU_NAME=custom; }
  [[ -n ${FANWATCH_GPU_TEMP:-} ]] && { HW_GPU=$FANWATCH_GPU_TEMP; HW_GPU_NAME=custom; }

  if [[ -z $HW_CPU ]]; then
    if   d=$(hwmon_dir_by_name "$root" '^coretemp$');            [[ -n $d ]]; then HW_CPU=$(hwmon_temp_by_label "$d" 'Package id')
    elif d=$(hwmon_dir_by_name "$root" '^(k10temp|zenpower)$');  [[ -n $d ]]; then HW_CPU=$(hwmon_temp_by_label "$d" 'Tctl|Tdie')
    elif d=$(hwmon_dir_by_name "$root" 'cpu[-_]?thermal|soc[-_]?thermal'); [[ -n $d ]]; then HW_CPU=$(hwmon_temp_by_label "$d" 'cpu')
    elif d=$(hwmon_dir_by_name "$root" '^thinkpad$');            [[ -n $d ]]; then HW_CPU=$(hwmon_temp_by_label "$d" '^CPU$')
    elif d=$(hwmon_dir_by_name "$root" '^acpitz$');              [[ -n $d ]]; then HW_CPU=$d/temp1_input
    fi
    [[ -n $d && -r $d/name ]] && read -r HW_CPU_NAME < "$d/name"
  fi

  if [[ -z $HW_GPU ]]; then
    if   d=$(hwmon_dir_by_name "$root" '^amdgpu$');   [[ -n $d ]]; then HW_GPU=$(hwmon_temp_by_label "$d" 'edge'); HW_GPU_NAME=amdgpu
    elif d=$(hwmon_dir_by_name "$root" '^thinkpad$'); [[ -n $d ]]; then HW_GPU=$(hwmon_temp_by_label "$d" '^GPU$'); HW_GPU_NAME=thinkpad
    elif command -v nvidia-smi >/dev/null 2>&1;       then HW_GPU=nvidia-smi; HW_GPU_NAME=nvidia
    fi
  fi

  if [[ -n ${FANWATCH_FAN:-} ]]; then
    read -ra HW_FANS <<< "$FANWATCH_FAN"
  else
    local f fans
    for d in "$root"/hwmon*; do
      fans=("$d"/fan*_input)
      [[ -r ${fans[0]} ]] || continue
      for f in "${fans[@]}"; do [[ -r $f ]] && HW_FANS+=("$f"); done
      [[ -z $HW_PWM && -r $d/pwm1 ]] && HW_PWM=$d/pwm1
      break
    done
  fi
  [[ -n ${FANWATCH_PWM:-} ]] && HW_PWM=$FANWATCH_PWM
  return 0
}

# Read a hwmon temperature input (millidegrees) as whole °C, rounded. Returns
# non-zero (echoing nothing) when the path is unreadable or not a number.
read_mC() {
  local f=$1 v
  [[ -r $f ]] || return 1
  read -r v < "$f" 2>/dev/null || return 1
  [[ $v =~ ^-?[0-9]+$ ]] || return 1
  printf '%d' "$(( (v + 500) / 1000 ))"
}

# --- per-backend samplers ---------------------------------------------------
sample_thinkpad() {
  cpu=""; gpu=""; rpm=""; rpmdisp="--"; leveltext="--"; levelcolor=$GR; levelkey=""; fanoff=0
  read -r cpu gpu _ < <(awk -F'\t' '/^temperatures:/{print $2}' "$IBM_THERMAL" | awk '{print $1, $2}')
  local level speed
  level=$(awk '/^level:/{print $2}' "$IBM_FAN")
  speed=$(awk '/^speed:/{print $2}' "$IBM_FAN")
  rpm=$speed; rpmdisp=${speed:---}
  levelkey=$level
  if   [[ $level == "0" ]];                            then leveltext="0 (off)"; levelcolor=$G; fanoff=1
  elif [[ $level == "full-speed" || $level == "7" ]];  then leveltext=$level;     levelcolor=$R
  else                                                      leveltext=$level;     levelcolor=$Y; fi
  [[ -n $cpu ]]
}

sample_hwmon() {
  cpu=""; gpu=""; rpm=""; rpmdisp="--"; leveltext="--"; levelcolor=$GR; levelkey=""; fanoff=0
  cpu=$(read_mC "$HW_CPU") || cpu=""
  if [[ $HW_GPU == nvidia-smi ]]; then
    gpu=$(nvidia-smi --query-gpu=temperature.gpu --format=csv,noheader,nounits 2>/dev/null | head -1)
    [[ $gpu =~ ^[0-9]+$ ]] || gpu=""
  elif [[ -n $HW_GPU ]]; then
    gpu=$(read_mC "$HW_GPU") || gpu=""
  fi

  local f v max="" parts=()
  for f in "${HW_FANS[@]}"; do
    [[ -r $f ]] || continue
    read -r v < "$f" 2>/dev/null || continue
    [[ $v =~ ^[0-9]+$ ]] || continue
    parts+=("$v"); { [[ -z $max ]] || (( v > max )); } && max=$v
  done
  if (( ${#parts[@]} )); then
    rpm=$max
    local IFS=/; rpmdisp="${parts[*]}"
  fi

  if [[ -n $HW_PWM && -r $HW_PWM ]]; then
    read -r v < "$HW_PWM" 2>/dev/null
    if [[ $v =~ ^[0-9]+$ ]]; then
      local pct=$(( (v*100 + 127) / 255 ))
      leveltext="${pct}%"; levelkey=$pct
      if   (( pct == 0 )); then levelcolor=$G
      elif (( pct < 50 )); then levelcolor=$C
      elif (( pct < 80 )); then levelcolor=$Y
      else                      levelcolor=$R; fi
    fi
  fi

  if   [[ -n $rpm ]];      then (( rpm == 0 )) && fanoff=1
  elif [[ $levelkey == 0 ]]; then fanoff=1; fi
  [[ -z $levelkey && -n $rpm ]] && levelkey="rpm:$rpm"
  [[ -n $cpu ]]
}

# --- macOS (SMC via an optional helper tool) --------------------------------
# macOS has no /sys or /proc/acpi; temperatures and fan RPM live in the SMC,
# which an unprivileged process cannot read without a helper. fanwatch uses
# whichever helper is on PATH, preferring ones that work on both Intel and Apple
# Silicon: smctemp covers cpu/gpu/fan, istats covers cpu temp + fan (Intel-era),
# osx-cpu-temp covers cpu temp only, and powermetrics is a sudo fallback for cpu
# temperature. Override the auto-pick with FANWATCH_MAC_TOOL.
discover_macos() {
  MAC_TEMP_TOOL=""; MAC_FAN_TOOL=""; MAC_GPU=0
  local pick=${FANWATCH_MAC_TOOL:-}
  if   [[ -n $pick ]] && command -v "$pick"  >/dev/null 2>&1; then MAC_TEMP_TOOL=$pick
  elif command -v smctemp      >/dev/null 2>&1; then MAC_TEMP_TOOL=smctemp
  elif command -v istats       >/dev/null 2>&1; then MAC_TEMP_TOOL=istats
  elif command -v osx-cpu-temp >/dev/null 2>&1; then MAC_TEMP_TOOL=osx-cpu-temp
  elif command -v powermetrics >/dev/null 2>&1; then MAC_TEMP_TOOL=powermetrics
  fi
  case $MAC_TEMP_TOOL in
    smctemp) MAC_FAN_TOOL=smctemp; MAC_GPU=1 ;;
    istats)  MAC_FAN_TOOL=istats ;;
  esac
  return 0
}

# Echo a number found on stdin, rounded to a whole integer, so a tool's exact
# formatting does not matter. Default picks the first number (right for a temp
# like "61.8°C"); "max" picks the largest, which is right for fan lines that
# carry an index ("Fan 0: 2345 rpm" -> 2345, not 0). Non-zero when no number.
mac_round() {
  local n
  if [[ ${1:-} == max ]]; then n=$(grep -oE '[0-9]+(\.[0-9]+)?' | sort -rn | head -1)
  else                         n=$(grep -oE '[0-9]+(\.[0-9]+)?' | head -1); fi
  [[ -n $n ]] || return 1
  printf '%.0f' "$n"
}

# CPU/GPU temperature in whole °C via the detected tool; non-zero if the tool
# cannot supply that reading (e.g. istats has no GPU sensor).
mac_temp() {
  case "$MAC_TEMP_TOOL:$1" in
    smctemp:cpu)      smctemp -c 2>/dev/null | mac_round ;;
    smctemp:gpu)      smctemp -g 2>/dev/null | mac_round ;;
    istats:cpu)       istats cpu temp --value-only 2>/dev/null | mac_round ;;
    osx-cpu-temp:cpu) osx-cpu-temp 2>/dev/null | mac_round ;;
    powermetrics:cpu) sudo -n powermetrics --samplers smc -i1 -n1 2>/dev/null \
                        | grep -i 'CPU die temperature' | mac_round ;;
    *) return 1 ;;
  esac
}

# Fan RPM via the detected tool (first fan if several); non-zero if unavailable.
mac_fan() {
  case $MAC_FAN_TOOL in
    smctemp) smctemp -f 2>/dev/null | mac_round max ;;
    istats)  istats fan speed --value-only 2>/dev/null | mac_round max ;;
    *) return 1 ;;
  esac
}

sample_macos() {
  cpu=""; gpu=""; rpm=""; rpmdisp="--"; leveltext="--"; levelcolor=$GR; levelkey=""; fanoff=0
  cpu=$(mac_temp cpu) || cpu=""
  (( MAC_GPU )) && { gpu=$(mac_temp gpu) || gpu=""; }
  if [[ -n $MAC_FAN_TOOL ]]; then
    rpm=$(mac_fan) || rpm=""
    if [[ -n $rpm ]]; then
      rpmdisp=$rpm; levelkey="rpm:$rpm"
      # No commanded PWM is exposed, so the level column shows on/off from RPM.
      if (( rpm > 0 )); then leveltext="on"; levelcolor=$Y
      else                   leveltext="off"; levelcolor=$G; fanoff=1; fi
    fi
  fi
  [[ -n $cpu ]]
}

sample() { "sample_$BACKEND"; }

# --- colors -----------------------------------------------------------------
if [[ -t 1 ]]; then
  R=$'\e[31m'; G=$'\e[32m'; Y=$'\e[33m'; B=$'\e[34m'; C=$'\e[36m'
  GR=$'\e[90m'; BOLD=$'\e[1m'; RST=$'\e[0m'
else
  R='' G='' Y='' B='' C='' GR='' BOLD='' RST=''
fi

# color a temperature by how hot it is
tcolor() { local t=$1
  if   (( t < OFF_BELOW )); then printf '%s' "$G"
  elif (( t < 70 ));        then printf '%s' "$C"
  elif (( t < 82 ));        then printf '%s' "$Y"
  else                           printf '%s' "$R"; fi
}

# trend arrow comparing current vs previous
arrow() { local cur=$1 prev=$2
  [[ -z $prev ]] && { printf ' '; return; }
  if   (( cur > prev )); then printf '%s▲%s' "$Y" "$RST"
  elif (( cur < prev )); then printf '%s▼%s' "$B" "$RST"
  else                        printf '%s—%s' "$GR" "$RST"; fi
}

# sparkline of the CPU history array, scaled 40..90C
SPARK=(▁ ▂ ▃ ▄ ▅ ▆ ▇ █)
hist=()
sparkline() {
  local out="" v idx lo=40 hi=90 span=$((90-40))
  for v in "${hist[@]}"; do
    (( v < lo )) && v=$lo; (( v > hi )) && v=$hi
    idx=$(( (v-lo)*7/span ))
    out+="${SPARK[$idx]}"
  done
  printf '%s' "$out"
}

# --- culprit attribution ----------------------------------------------------
# Temperature lags load, so when a rise is seen the culprit is whatever has
# been driving the CPU/GPU over the last moment. These run ONLY on a rise, so
# the steady-state loop stays cheap.

# Top CPU consumers right now, aggregated by program name. Uses top's SECOND
# iteration (recent %CPU, not the lifetime average ps reports) and resolves clean
# names from /proc/<pid>/cmdline (top's COMMAND column and comm both truncate),
# then sums per name so multi-process apps (browsers!) show their true total.
# Skips top/fanwatch/self. e.g. "brave 212% · gnome-shell 23% · claude 21%"
culprit_cpu() {
  local pid pct name cl
  while read -r pid pct; do
    # prefer the full executable basename from cmdline; fall back to comm
    # (kernel-capped at 15 chars). Skip if the process already exited.
    name=""
    [[ -r /proc/$pid/comm ]] && read -r name < "/proc/$pid/comm"
    if [[ -r /proc/$pid/cmdline ]]; then
      cl=$(tr '\0' ' ' < "/proc/$pid/cmdline"); cl=${cl%% *}; cl=${cl##*/}
      [[ -n $cl ]] && name=$cl
    fi
    [[ -z $name || $name == top || $name == fanwatch ]] && continue
    printf '%s %s\n' "$name" "$pct"
  done < <(top -bn2 -d 0.2 2>/dev/null | awk '
      /^[[:space:]]*PID/ { p++; next }
      p == 2 { pct=$9; sub(",", ".", pct); if (pct+0 >= 1) print $1, pct }') \
  | awk '{ sum[$1]+=$2 } END { for (k in sum) printf "%.0f %s\n", sum[k], k }' \
  | sort -rn | head -3 \
  | awk '{ printf "%s%s %s%%", sep, $2, $1; sep=" · " }'
}

# GPU consumers via nvidia-smi process monitor — works in hybrid/Optimus mode
# for graphics apps (compute-apps query is usually empty there). e.g. "gnome-shell"
culprit_gpu() {
  command -v nvidia-smi >/dev/null 2>&1 || return
  nvidia-smi pmon -c 1 2>/dev/null \
  | awk 'NR>2 && $2 ~ /^[0-9]+$/ { print $NF }' \
  | sort -u | paste -sd' · ' -
}

# macOS CPU culprit: /proc and `top -bn2` are absent, so use ps's recent %CPU
# (-c gives the clean accounting name, which may contain spaces) aggregated by
# name. e.g. "Safari 180% · WindowServer 22% · Code 14%"
culprit_cpu_mac() {
  ps -Ac -o pcpu,comm 2>/dev/null \
  | awk 'NR>1 { pc=$1+0; if (pc<1) next; name=$2; for(i=3;i<=NF;i++) name=name" "$i;
                if (name=="fanwatch"||name=="ps"||name=="awk") next; sum[name]+=pc }
         END { for (k in sum) printf "%.0f\t%s\n", sum[k], k }' \
  | sort -rn | head -3 \
  | awk -F'\t' '{ printf "%s%s %s%%", sep, $2, $1; sep=" · " }'
}

# When sourced (by the tests), stop here: everything above is definitions and
# read-only discovery; everything below sets up the terminal, prints, and loops.
[[ ${BASH_SOURCE[0]} != "$0" ]] && return 0

# --- backend setup ----------------------------------------------------------
# Pick the backend, then resolve its sensors and the coloring threshold. OFF_BELOW
# is the temperature below which a CPU reading is "cool" (green): thinkfan derives
# it from its config; hwmon uses FANWATCH_OFF_BELOW. BACKEND_DESC labels the
# active source in the header, OFF_NOTE adds the thinkpad fan-off hint.
BACKEND=$(detect_backend)
if ! declare -F "sample_$BACKEND" >/dev/null; then
  printf 'fanwatch: unknown backend %q (set FANWATCH_BACKEND to thinkpad, hwmon, or macos)\n' "$BACKEND" >&2
  exit 1
fi

OFF_NOTE=""
case $BACKEND in
  thinkpad)
    OFF_BELOW=$(parse_off_below "$THINKFAN_CONFIG")
    BACKEND_DESC="thinkpad_acpi"
    [[ -r $THINKFAN_CONFIG ]] && BACKEND_DESC="thinkpad_acpi + thinkfan"
    OFF_NOTE=", fan off < ${OFF_BELOW}°C"
    ;;
  hwmon)
    discover_hwmon "${FANWATCH_HWMON_ROOT:-/sys/class/hwmon}"
    OFF_BELOW="${FANWATCH_OFF_BELOW:-55}"
    [[ -n $HW_CPU ]] || { printf 'fanwatch: no CPU temperature sensor found under %s (set FANWATCH_CPU_TEMP)\n' "${FANWATCH_HWMON_ROOT:-/sys/class/hwmon}" >&2; exit 1; }
    BACKEND_DESC="hwmon: ${HW_CPU_NAME:-cpu}"
    [[ -n $HW_GPU_NAME ]] && BACKEND_DESC+=" + $HW_GPU_NAME"
    ;;
  macos)
    discover_macos
    OFF_BELOW="${FANWATCH_OFF_BELOW:-55}"
    [[ -n $MAC_TEMP_TOOL ]] || { printf 'fanwatch: no macOS sensor tool found. Install smctemp, istats or osx-cpu-temp (e.g. brew install smctemp), or run where sudo powermetrics works.\n' >&2; exit 1; }
    BACKEND_DESC="macos: $MAC_TEMP_TOOL"
    [[ -n $MAC_FAN_TOOL && $MAC_FAN_TOOL != "$MAC_TEMP_TOOL" ]] && BACKEND_DESC+=" + $MAC_FAN_TOOL"
    ;;
esac

# --- terminal dimensions ----------------------------------------------------
# COLS/ROWS are the usable width/height, or 0 when output is not a terminal (no
# pinned header there). A WINCH trap refreshes them on resize, so we only shell
# out to tput then.
COLS=0; ROWS=0
get_dims() {
  [[ -t 1 ]] || { COLS=0; ROWS=0; return; }
  # tput can fail (TERM unset/dumb) or report 0; fall back to the shell's
  # COLUMNS/LINES, then 80x24. COLS must never be 0 on a terminal: it would be
  # indistinguishable from "not a terminal" and disable the pinned layout.
  local c r
  c=$(tput cols  2>/dev/null); [[ $c =~ ^[1-9][0-9]*$ ]] || c=${COLUMNS-}; [[ $c =~ ^[1-9][0-9]*$ ]] && COLS=$c || COLS=80
  r=$(tput lines 2>/dev/null); [[ $r =~ ^[1-9][0-9]*$ ]] || r=${LINES-};   [[ $r =~ ^[1-9][0-9]*$ ]] && ROWS=$r || ROWS=24
}
get_dims

# --- keyboard ---------------------------------------------------------------
# The Shift+Tab hotkey needs single keypresses (non-canonical, no-echo input)
# and bash 5 for the EPOCHREALTIME-paced idle below. Enable it only on a real
# terminal (not under the tests or a pipe). Save the termios to restore on exit.
KB=0; STTY_SAVE=""
if (( BASH_VERSINFO[0] >= 5 )) && [[ -t 0 ]] && STTY_SAVE=$(stty -g 2>/dev/null); then
  stty -icanon -echo 2>/dev/null && KB=1
fi
restore_tty() { (( KB )) && [[ -n $STTY_SAVE ]] && stty "$STTY_SAVE" 2>/dev/null; }
trap restore_tty EXIT

STICKY=0
cleanup() {
  # Release the scroll region and drop the cursor below the data before resetting
  # color, so the shell prompt returns under the output rather than over the
  # pinned header. The tty mode is restored separately by the EXIT trap above.
  (( STICKY )) && printf '\e[r\e[%d;1H' "$ROWS"
  printf '%s\n' "$RST"
  exit 0
}
trap cleanup INT TERM

# --- header -----------------------------------------------------------------
# Build the two header lines into hdr_lines[]. Kept in a function because the
# pinned layout reprints it on resize and on a live toggle. The layout tag (cyan
# PINNED vs yellow SCROLLING) reflects FANWATCH_STICKY, i.e. the mode the toggle
# currently selects, so a Shift+Tab press is unmistakable.
hdr_lines=()
build_header() {
  local keys="" tag h0 h1
  if (( COLS != 0 )); then
    if (( STICKY_PREF )); then printf -v tag '%s▔ PINNED%s'    "$C" "$RST"
    else                       printf -v tag '%s↕ SCROLLING%s' "$Y" "$RST"; fi
    printf -v keys '   %s  %sShift+Tab toggles%s' "$tag" "$GR" "$RST"
  fi
  printf -v h0 '%sfanwatch%s  every %ss, Ctrl+C to quit   (%s%s)%s' \
    "$BOLD" "$RST" "$interval" "$BACKEND_DESC" "$OFF_NOTE" "$keys"
  printf -v h1 '%s%-8s  %-7s  %-7s  %-11s  %-9s  %s%s' \
    "$GR" "time" "CPU" "GPU" "fan" "rpm" "cpu trend (40-90°C)" "$RST"
  hdr_lines=("$h0" "$h1")
}

# Paint the header. HDR_ROWS records its height for the scroll-mode reprint
# cadence. In pinned mode (sticky preferred, on a terminal with rows to spare):
# clear the screen, print the header at the top, then confine scrolling to the
# rows below it with a DECSTBM scroll region, so data scrolls under a fixed
# header (rows that scroll past are lost to scrollback). Otherwise print it
# inline and let everything scroll; the main loop then reprints it each screenful
# so it stays visible while old rows remain in the terminal's scrollback.
HDR_ROWS=0
render_header() {
  build_header
  HDR_ROWS=${#hdr_lines[@]}
  if (( ! STICKY_PREF )) || (( COLS == 0 )) || (( ROWS <= HDR_ROWS + 1 )); then
    STICKY=0
    printf '%s\n' "${hdr_lines[@]}"
    return
  fi
  STICKY=1
  printf '\e[H\e[2J'                            # home + clear screen
  printf '%s\n' "${hdr_lines[@]}"               # header occupies rows 1..HDR_ROWS
  printf '\e[%d;%dr' "$((HDR_ROWS+1))" "$ROWS"  # scroll region: below header .. bottom
  printf '\e[%d;1H' "$((HDR_ROWS+1))"           # park the cursor at its top
}

# A resize refreshes the dimensions; pinned mode also repaints to re-establish
# the scroll region. Scroll mode just adopts the new size on its next screenful.
winch_handler() { get_dims; (( STICKY )) && render_header; }
render_header
trap winch_handler WINCH

# Flip the layout live (Shift+Tab). Leaving pinned mode releases the scroll
# region first; render_header then repaints in whichever mode is now selected.
toggle_sticky() {
  (( STICKY_PREF = ! STICKY_PREF ))
  (( STICKY )) && printf '\e[r'      # drop the old scroll region before repaint
  rows_since_hdr=0
  render_header
}

# Idle until the next tick. On a keyboard terminal, poll stdin instead of
# sleeping so Shift+Tab (ESC [ Z) is handled promptly; a read timeout means the
# interval elapsed. Without a keyboard, just sleep.
idle() {
  (( KB )) || { sleep "$interval"; return; }
  local deadline to key rest
  deadline=$(awk -v n="$EPOCHREALTIME" -v i="$interval" 'BEGIN{printf "%.3f", n+i}')
  while :; do
    to=$(awk -v d="$deadline" -v n="$EPOCHREALTIME" \
         'BEGIN{r=d-n; if(r<=0) print "x"; else printf "%.3f", r}')
    [[ $to == x ]] && break                       # reached the deadline -> tick
    IFS= read -rsN1 -t "$to" key || break          # timeout/EOF -> tick now
    if [[ $key == $'\e' ]]; then                  # CSI? Shift+Tab is ESC [ Z
      IFS= read -rsN2 -t 0.05 rest
      [[ $rest == '[Z' ]] && toggle_sticky
    fi
  done
}

# --- main loop --------------------------------------------------------------
prev_cpu=""; prev_gpu=""; prev_levelkey=""; prev_leveltext=""; prev_fanoff=0; rows_since_hdr=0

while :; do
  sample || { idle; continue; }   # fills cpu/gpu/rpm/level*; non-zero if no CPU
  ts=$(date +%H:%M:%S)

  # track CPU history for the sparkline (keep last 40)
  hist+=("$cpu"); (( ${#hist[@]} > 40 )) && hist=("${hist[@]: -40}")

  # Assemble the row from coloured segments so the GPU column can drop out when
  # the backend has no GPU sensor, and so the level field pads on its plain text
  # (the colour codes around it would otherwise throw off %-Ns width counting).
  printf -v f_time '%s%-8s%s' "$GR" "$ts" "$RST"
  printf -v f_cpu  '%s%2s°C%s %s' "$(tcolor "$cpu")" "$cpu" "$RST" "$(arrow "$cpu" "$prev_cpu")"
  if [[ -n $gpu ]]; then
    printf -v f_gpu '%s%2s°C%s %s' "$(tcolor "$gpu")" "$gpu" "$RST" "$(arrow "$gpu" "$prev_gpu")"
  else
    printf -v f_gpu '%s  --   %s' "$GR" "$RST"
  fi
  printf -v f_lvl '%s%-11s%s' "$levelcolor" "$leveltext" "$RST"
  printf -v f_rpm '%-9s' "$rpmdisp"
  printf '%s  %s  %s  %s  %s  %s\n' "$f_time" "$f_cpu" "$f_gpu" "$f_lvl" "$f_rpm" "$(sparkline)"
  printed=1

  # culprit callout on a meaningful CPU temp rise
  if [[ -n $prev_cpu ]] && (( cpu - prev_cpu >= RISE )); then
    if [[ $BACKEND == macos ]]; then cpu_blame=$(culprit_cpu_mac); else cpu_blame=$(culprit_cpu); fi
    gpu_blame=$(culprit_gpu)
    line="   ${GR}└─ ${Y}▲ +$((cpu - prev_cpu))°C${GR}  likely: ${RST}${cpu_blame:-?}"
    [[ -n $gpu_blame ]] && line+="${GR}  │ gpu: ${RST}${gpu_blame}"
    printf '%s%s\n' "$line" "$RST"; (( printed++ ))
  fi

  # Callout when the fan state changes. Always report an off<->on transition; on
  # the thinkpad backend also report every discrete level change (2 -> 4 etc).
  # The hwmon PWM% wiggles tick to tick, so only its off<->on edges are flagged.
  if [[ -n $prev_levelkey ]]; then
    changed=0
    if   (( fanoff != prev_fanoff )); then changed=1
    elif [[ $BACKEND == thinkpad && $levelkey != "$prev_levelkey" ]]; then changed=1; fi
    if (( changed )); then
      if (( fanoff )); then
        printf '   %s└─ fan %s → %s%s%s  ✓ fan OFF (silent)%s\n' "$GR" "$prev_leveltext" "$BOLD$G" "$leveltext" "$RST$GR" "$RST"
      else
        dir="changed"; (( prev_fanoff )) && dir="spun up"
        printf '   %s└─ fan %s → %s%s%s  (%s)%s\n' "$GR" "$prev_leveltext" "$BOLD" "$leveltext" "$RST$GR" "$dir" "$RST"
      fi
      (( printed++ ))
    fi
  fi

  # Scroll mode on a terminal: once a screenful of rows has gone by, reprint the
  # header inline so it stays in view while the rows it scrolled past remain in
  # the terminal's scrollback. (Pinned mode's scroll region handles this itself.)
  if (( ! STICKY && COLS > 0 )); then
    screenful=$(( ROWS - HDR_ROWS )); (( screenful < 1 )) && screenful=1
    (( rows_since_hdr += printed ))
    if (( rows_since_hdr >= screenful )); then render_header; rows_since_hdr=0; fi
  fi

  prev_cpu=$cpu; prev_gpu=$gpu
  prev_levelkey=$levelkey; prev_leveltext=$leveltext; prev_fanoff=$fanoff
  idle
done
